{
  "name": "@uab/cli",
  "version": "0.1.0",
  "description": "CLI for serving and calling real Universal Agent Bridge runtimes.",
  "type": "module",
  "bin": {
    "uab": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "serve": "node ./dist/index.js serve"
  },
  "dependencies": {
    "@uab/a2a": "file:../a2a",
    "@uab/adapter-hermes": "file:../adapter-hermes",
    "@uab/adapter-http-jsonrpc": "file:../adapter-http-jsonrpc",
    "@uab/adapter-openclaw": "file:../adapter-openclaw",
    "@uab/core": "file:../core",
    "@uab/mcp": "file:../mcp",
    "@uab/protocol": "file:../protocol",
    "@uab/transport-http": "file:../transport-http"
  }
}
