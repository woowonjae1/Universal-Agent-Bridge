{
  "name": "universal-agent-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Transport-agnostic control plane for managing multiple AI agent runtimes through a unified RPC protocol.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b && npm --workspace @uab/dashboard run build",
    "build:packages": "tsc -b",
    "clean": "node scripts/clean.mjs",
    "dashboard": "npm --workspace @uab/dashboard run dev",
    "dashboard:build": "npm --workspace @uab/dashboard run build",
    "demo": "node packages/cli/dist/index.js demo",
    "dev:api": "node packages/cli/dist/index.js serve --port 8787",
    "example:agent": "node examples/http-agent/server.mjs",
    "serve": "node packages/cli/dist/index.js serve",
    "test": "node scripts/run-tests.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.2",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
